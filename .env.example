# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
# Públicas (expuestas al navegador):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solo servidor — NUNCA exponer al cliente ni prefijar con NEXT_PUBLIC_:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────────────────────
# Notificaciones (n8n)
# Webhook que gestiona email + WhatsApp. Solo se invoca desde el servidor.
# ─────────────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/aranha-leads

# ─────────────────────────────────────────────────────────────────────────────
# Marca / contacto
# Teléfono de WhatsApp en formato internacional sin '+' ni espacios (ej: 34600000000)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=34600000000

# URL canónica del sitio (para metadata, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://aranhabaile.com
